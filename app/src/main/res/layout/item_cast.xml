<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="item"
            type="com.karrar.movieapp.ui.models.ActorUiState" />

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.adapters.ActorsInteractionListener" />
    </data>
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/background_color_card"
        app:cardElevation="0dp"
        app:cardCornerRadius="12dp"
        android:onClick="@{() -> listener.onClickActor(item.id)}">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="200dp"
            android:layout_height="64dp">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/cast_image"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="centerCrop"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:posterImage="@{item.imageUrl}"
                app:shapeAppearanceOverlay="@style/CastImage"
                tools:srcCompat="@drawable/image" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/cast_image"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    style="@style/TextStyle.Body.Medium.Medium"
                    android:id="@+id/cast_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:lines="1"
                    android:text="@{item.name}"
                    android:textColor="@color/shade_color_primary"
                    tools:text="Cristian Bale kkkkkkkkkkjjjnnnnn" />

                <TextView
                    style="@style/TextStyle.Body.Small.Regular"
                    android:id="@+id/cast_character"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:lines="1"
                    android:text="@{item.charName}"
                    android:textColor="@color/shade_color_secondary"
                    tools:text="Bruce Wayne" />
            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.cardview.widget.CardView>


</layout>