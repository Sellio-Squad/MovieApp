<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="item"
            type="com.karrar.movieapp.ui.models.MediaUiState" />

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.adapters.TvShowDetailsInteractionListener" />
    </data>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="95dp"
        android:layout_margin="8dp"
        android:clickable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:onClick="@{() -> listener.onClickTvShow(item)}"
        app:cardBackgroundColor="@color/background_color_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/content_row"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="64dp"
                    android:layout_height="match_parent"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    app:cardUseCompatPadding="false"
                    app:shapeAppearanceOverlay="@style/PosterShapeStyle"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:id="@+id/img_poster"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/image_error_palceholder"
                        android:contentDescription="@string/movie_poster"
                        android:scaleType="centerCrop"
                        app:mediaPoster="@{item.imageUrl}" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/movie_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@{item.mediaTitle}"
                        android:textAppearance="@style/TextStyle.Body.Medium.Medium"
                        android:textColor="@color/shade_color_primary"
                        tools:text="The Dark Knight" />

                    <TextView
                        android:id="@+id/movie_genres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                        android:textColor="@color/shade_color_secondary"
                        tools:text="Drama, Action, Crime, Thriller" />

                    <LinearLayout
                        android:id="@+id/release_date_section"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/calendar_icon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="@string/release_date"
                            android:src="@drawable/calendar"
                            app:tint="@color/shade_color_secondary" />

                        <!--                        <TextView-->
                        <!--                            android:id="@+id/release_date"-->
                        <!--                            android:layout_width="wrap_content"-->
                        <!--                            android:layout_height="wrap_content"-->
                        <!--                            android:layout_marginStart="4dp"-->
                        <!--                            android:text="@{item.mediaReleaseDate}"-->
                        <!--                            tools:text="2008, Jul 18"-->
                        <!--                            android:textAppearance="@style/TextStyle.Label.Medium.Regular"-->
                        <!--                            android:textColor="@color/shade_color_secondary" />-->
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rating_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_margin="8dp"
                android:background="@drawable/media_rate_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:transitionName="@{`media_rating_` + item.id}">

                <TextView
                    android:id="@+id/movie_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{String.valueOf(item.rate)}"
                    android:textAppearance="@style/TextStyle.Label.Medium.Medium"
                    android:textColor="@color/shade_color_primary"
                    android:textStyle="bold"
                    tools:text="7.5" />

                <ImageView
                    android:id="@+id/star_icon"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="2dp"
                    android:contentDescription=""
                    android:src="@drawable/ic_rate" />
            </LinearLayout>

        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</layout>