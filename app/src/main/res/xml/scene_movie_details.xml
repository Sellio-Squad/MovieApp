<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <Transition
        motion:constraintSetStart="@id/start"
        motion:constraintSetEnd="@id/end"
        motion:duration="800"
        motion:motionInterpolator="anticipateOvershoot">

        <KeyFrameSet>
            <KeyAttribute
                motion:motionTarget="@id/fullHeader"
                motion:framePosition="25"
                android:alpha="0.8"
                android:scaleX="0.98"
                android:scaleY="0.98"
                android:translationY="-10dp" />

            <KeyAttribute
                motion:motionTarget="@id/fullHeader"
                motion:framePosition="75"
                android:alpha="0.2"
                android:scaleX="0.9"
                android:scaleY="0.9"
                android:translationY="-25dp" />

            <KeyAttribute
                motion:motionTarget="@id/minHeader"
                motion:framePosition="25"
                android:alpha="0.2"
                android:scaleX="0.95"
                android:scaleY="0.95"
                android:translationY="8dp" />

            <KeyAttribute
                motion:motionTarget="@id/minHeader"
                motion:framePosition="75"
                android:alpha="0.7"
                android:scaleX="1.02"
                android:scaleY="1.02"
                android:translationY="0dp" />
        </KeyFrameSet>

    </Transition>

    <ConstraintSet android:id="@+id/start">
        <Constraint
            android:id="@id/fullHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            motion:layout_constraintTop_toTopOf="parent"
            android:alpha="1" />

        <Constraint
            android:id="@id/minHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            motion:layout_constraintTop_toTopOf="parent"
            android:alpha="0" />
    </ConstraintSet>

    <ConstraintSet android:id="@+id/end">
        <Constraint
            android:id="@id/fullHeader"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            motion:layout_constraintTop_toTopOf="parent"
            android:alpha="0" />

        <Constraint
            android:id="@id/minHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            motion:layout_constraintTop_toTopOf="parent"
            android:alpha="1" />
    </ConstraintSet>
</MotionScene>
