<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="item"
            type="com.karrar.movieapp.ui.explore.exploreUIState.MediaUIState" />
        <variable
            name="listener"
            type="com.karrar.movieapp.ui.explore.CategoryInteractionListener" />
    </data>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="95dp"
        android:layout_margin="8dp"
        android:clickable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:onClick="@{() -> listener.onClickCategory(item.mediaID)}"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/background_color_card">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/content_row"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="64dp"
                    android:layout_height="match_parent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardPreventCornerOverlap="false"
                    app:cardUseCompatPadding="false"
                    app:shapeAppearanceOverlay="@style/PosterShapeStyle">

                    <ImageView
                        android:id="@+id/img_poster"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@drawable/image_error_palceholder"
                        app:mediaPoster="@{item.mediaImage}"
                        android:contentDescription="@string/movie_poster" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/movie_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@{item.mediaName}"
                        tools:text="The Dark Knight"
                        android:textAppearance="@style/TextStyle.Body.Medium.Medium"
                        android:textColor="@color/shade_color_primary"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/movie_genres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@{item.mediaGenre}"
                        tools:text="Drama, Action, Crime, Thriller"
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                        android:textColor="@color/shade_color_secondary"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <LinearLayout
                        android:id="@+id/release_date_section"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/calendar_icon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/calendar"
                            app:tint="@color/shade_color_secondary"
                            android:contentDescription="@string/release_date" />

                        <TextView
                            android:id="@+id/release_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@{item.mediaReleaseDate}"
                            tools:text="2008, Jul 18"
                            android:textAppearance="@style/TextStyle.Label.Medium.Regular"
                            android:textColor="@color/shade_color_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rating_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_margin="8dp"
                android:orientation="horizontal"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:transitionName="@{`media_rating_` + item.mediaID}"
                android:background="@drawable/media_rate_background"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/movie_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{String.valueOf(item.mediaVoteAverage)}"
                    tools:text="7.5"
                    android:textAppearance="@style/TextStyle.Label.Medium.Medium"
                    android:textStyle="bold"
                    android:textColor="@color/shade_color_primary" />

                <ImageView
                    android:id="@+id/star_icon"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="2dp"
                    android:src="@drawable/ic_rate"
                    android:contentDescription="" />
            </LinearLayout>

        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</layout>