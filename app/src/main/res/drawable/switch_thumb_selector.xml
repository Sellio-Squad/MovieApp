<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <layer-list>
            <item android:width="25dp" android:height="25dp" android:bottom="2dp" android:gravity="center" android:left="1dp" android:right="1dp" android:top="2dp">
                <shape android:shape="oval">
                    <solid android:color="#FFFFFF" />
                    <stroke android:width="2dp" android:color="@color/brand_color_primary" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Unchecked state (OFF) -->
    <item android:state_checked="false">
        <layer-list>
            <item android:width="25dp" android:height="25dp" android:bottom="2dp" android:gravity="center" android:left="1dp" android:right="1dp" android:top="2dp">
                <shape android:shape="oval">
                    <solid android:color="@color/shade_color_secondary" />
                    <stroke android:width="2dp" android:color="@color/white" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>