<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Keep background transparent -->
    <solid android:color="@android:color/transparent" />

    <!-- Bottom-only line using stroke + padding -->
    <stroke
        android:width="1dp"
        android:color="@color/shade_color_secondary" />

    <padding
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="-1dp" />
</shape>
