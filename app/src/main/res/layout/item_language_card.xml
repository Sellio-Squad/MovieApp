<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="isSelected"
            type="Boolean" />

        <variable
            name="item"
            type="com.karrar.movieapp.ui.profile.settings.language.AppLanguages" />

    </data>

    <LinearLayout
        android:layout_width="146dp"
        android:layout_height="87dp"
        android:background="@drawable/language_card_background"
        android:gravity="center"
        android:orientation="vertical"
        android:selected="@{isSelected}">

        <ImageView
            android:id="@+id/icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginBottom="@dimen/spacing_too_small"
            android:contentDescription="@string/icon"
            app:imageRes="@{item.icon}" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/txt_title"
            style="@style/TextStyle.Body.Medium.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_too_small"
            android:textColor="@{isSelected ? @color/brand_color_primary : @color/shade_color_primary}"
            app:textRes="@{item.language}" />

    </LinearLayout>
</layout>
