<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.home.adapter.YourCollectionsInteractionListener" />

        <variable
            name="movieType"
            type="com.karrar.movieapp.domain.enums.HomeItemsType" />

        <variable
            name="adapterRecycler"
            type="com.karrar.movieapp.ui.home.adapter.YourCollectionsAdapter" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/spacing_medium">

        <com.karrar.movieapp.utilities.common.SectionHeaderView
            android:id="@+id/header"
            style="@style/TextStyle.Title.Small"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@{movieType.stringRes != 0 ? context.getString(movieType.stringRes) : @string/you_recently_viewed}"
            android:textColor="@color/shade_color_primary"
            app:isVisible="@{adapterRecycler.itemCount != 0}"
            app:layout_constraintTop_toTopOf="parent"
            app:onSeeAllClick="@{() -> adapterRecycler.listener.onClickSeeAllCollections()}"
            app:showSeeAll="true"
            tools:text="Popular" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_movie"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_simi_medium"
            android:adapter="@{adapterRecycler}"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:overScrollMode="never"
            android:paddingHorizontal="16dp"
            android:scrollbars="none"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/header"
            app:spanCount="2"
            tools:listitem="@layout/item_my_collection" />

    </androidx.constraintlayout.widget.ConstraintLayout>


</layout>