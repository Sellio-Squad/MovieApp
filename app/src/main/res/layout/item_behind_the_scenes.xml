<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="24dp">

    <TextView
        android:id="@+id/behind_the_scenes_section_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/manrope_medium"
        android:text="@string/behind_the_scenes_section_title"
        android:textColor="#E1E1E3"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/behind_the_scenes_section_showMore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/manrope_medium"
        android:text="@string/behind_the_scenes_section_show_more"
        android:textColor="#8C9EFF"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="#1B1C2A"
        app:cardCornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/behind_the_scenes_section_title">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/behind_the_scenes_section_characters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_regular"
                android:paddingVertical="18.5dp"
                android:text="@string/behind_the_scenes_section_characters"
                android:textColor="#A4A4AA"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/behind_the_scenes_section_characters_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="18.5dp"
                android:textColor="#E1E1E3"
                android:textSize="14sp"
                tools:text="Bob Kane"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/characters_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#242533"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/behind_the_scenes_section_characters" />

            <TextView
                android:id="@+id/behind_the_scenes_section_director"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_regular"
                android:paddingVertical="18.5dp"
                android:text="@string/behind_the_scenes_section_director"
                android:textColor="#A4A4AA"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/characters_divider" />

            <TextView
                android:id="@+id/behind_the_scenes_section_director_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="18.5dp"
                android:textColor="#E1E1E3"
                android:textSize="14sp"
                tools:text="Christopher Nolan"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/characters_divider" />

            <View
                android:id="@+id/director_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#242533"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/behind_the_scenes_section_director" />

            <TextView
                android:id="@+id/behind_the_scenes_section_screenplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_regular"
                android:paddingVertical="18.5dp"
                android:text="@string/behind_the_scenes_section_screenplay"
                android:textColor="#A4A4AA"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/director_divider" />

            <TextView
                android:id="@+id/behind_the_scenes_section_Screenplay_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="18.5dp"
                android:textColor="#E1E1E3"
                android:textSize="14sp"
                tools:text="Jonathan Nolan"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/director_divider" />

            <View
                android:id="@+id/screenplay_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#242533"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/behind_the_scenes_section_screenplay" />

            <TextView
                android:id="@+id/behind_the_scenes_section_story"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_regular"
                android:paddingVertical="18.5dp"
                android:text="@string/behind_the_scenes_section_story"
                android:textColor="#A4A4AA"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/screenplay_divider" />

            <TextView
                android:id="@+id/behind_the_scenes_section_story_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="18.5dp"
                android:textColor="#E1E1E3"
                android:textSize="14sp"
                tools:text="David S. Goyer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/screenplay_divider" />


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>


</androidx.constraintlayout.widget.ConstraintLayout>