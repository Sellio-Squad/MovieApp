<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Label -->
    <TextView
        android:id="@+id/textFieldLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/manrope_medium"
        android:textColor="@color/shade_color_secondary"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Input Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/inputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/cineverse_edittext_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- Leading Icon -->
            <ImageView
                android:id="@+id/leadingIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="12dp"
                app:tint="@color/shade_color_tertiary" />

            <!-- EditText -->
            <EditText
                android:id="@+id/editText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="@font/manrope_medium"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/shade_color_primary"
                android:textColorHint="@color/shade_color_tertiary"
                android:textSize="14sp" />

            <!-- Trailing Icon / Error Icon / Password Toggle -->
            <ImageView
                android:id="@+id/trailingIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:visibility="gone"
                app:tint="@color/shade_color_secondary" />

        </LinearLayout>

    </FrameLayout>

    <!-- Error Message -->
    <TextView
        android:id="@+id/errorMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/manrope_regular"
        android:textColor="@color/additional_color_primary_color_red"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Forgot Password -->
    <TextView
        android:id="@+id/forgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/manrope_regular"
        android:text="@string/forgot_password"
        android:textColor="@color/shade_color_secondary"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>