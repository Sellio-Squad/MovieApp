<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="listener"
            type="com.karrar.movieapp.ui.adapters.MovieInteractionListener" />

        <variable
            name="item"
            type="com.karrar.movieapp.ui.home.homeUiState.PopularUiState" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:onClick="@{()->listener.onClickMovie(item.movieID)}"
        android:paddingVertical="@dimen/spacing_small">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/image_movie"
                android:layout_width="@dimen/media_card_popular_movie"
                android:layout_height="200dp"
                android:layout_marginHorizontal="@dimen/spacing_small"
                android:scaleType="centerCrop"
                app:layout_constraintDimensionRatio="1.75:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:posterImage="@{item.imageUrl}"
                app:shapeAppearanceOverlay="@style/CardCorners.Medium" />

            <!-- Gradient Overlay -->
            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/gradient"
                app:layout_constraintBottom_toBottomOf="@id/image_movie"
                app:layout_constraintEnd_toEndOf="@id/image_movie"
                app:layout_constraintStart_toStartOf="@id/image_movie"
                app:layout_constraintTop_toTopOf="@id/image_movie"
                app:shapeAppearanceOverlay="@style/CardCorners.Medium" />

            <!-- Rating Badge -->
            <LinearLayout
                android:id="@+id/liner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/media_rate_background"
                android:gravity="center"
                android:layout_margin="@dimen/spacing_small"
                android:paddingHorizontal="@dimen/spacing_small"
                android:paddingVertical="@dimen/spacing_too_small"
                app:layout_constraintTop_toTopOf="@id/image_movie"
                app:layout_constraintEnd_toEndOf="@id/image_movie">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{String.format(`%.1f`, item.movieRate)}"
                    tools:text="5.7"
                    android:textColor="@color/shade_color_primary"
                    style="@style/TextStyle.Label.Medium.Medium" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/spacing_too_small"
                    android:src="@drawable/ic_rate" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Movie Title (outside card, centered) -->
        <TextView
            android:id="@+id/text_movie_title"
            style="@style/SemiBold.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:lines="1"
            android:maxWidth="240dp"
            android:gravity="center"
            android:text="@{item.title}"
            android:textColor="@color/white_primary"
            android:layout_marginTop="@dimen/spacing_small"
            tools:text="Inception" />

        <TextView
            android:id="@+id/text_category"
            style="@style/SemiBold.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/white_secondary"
            app:genre="@{item.genre}"
            android:layout_marginTop="@dimen/spacing_too_small"
            tools:text="Action • Sci-Fi" />

    </LinearLayout>
</layout>
