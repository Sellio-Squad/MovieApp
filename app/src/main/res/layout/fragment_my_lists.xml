<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.karrar.movieapp.ui.myList.MyListsViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.myCollection.MyCollectionFragment">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/saved_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="16dp"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:overScrollMode="never"
            android:paddingTop="@dimen/spacing_small"
            android:paddingBottom="80dp"
            app:items="@{viewModel.createdListUIState.createdList}"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:listitem="@layout/item_saved_list" />


        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/floating_action_button"
            style="@style/MovieAppFabStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:contentDescription="@string/fao"
            android:onClick="@{()->viewModel.onCreateList()}"
            app:backgroundTint="@color/brand_color_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/add_icon"
            app:tint="@color/button_color_onPrimary" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/succces_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="
                    saved_list,
                    floating_action_button"
            app:error="@{viewModel.createdListUIState.error}"
            app:loading="@{viewModel.createdListUIState.loading}" />

        <ProgressBar
            android:id="@+id/loading"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:indeterminateDrawable="@drawable/loading_shape_my_collection"
            app:isVisible="@{viewModel.createdListUIState.loading}"
            />

        <!-- Error State -->

        <ImageView
            android:id="@+id/animation_lost_connection"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/circle_red_my_collection"
            android:padding="18dp"
            app:layout_constraintVertical_chainStyle="packed"
            app:tint="@color/additional_color_primary_color_red"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/title_lost_connection"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/due_tone_station" />

        <TextView
            android:id="@+id/title_lost_connection"
            style="@style/TextStyle.Title.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/radius_cineVerse_xl"
            android:text="@string/oops_no_internet"
            android:textColor="@color/shade_color_primary"
            app:layout_constraintBottom_toTopOf="@id/description_lost_connection"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/animation_lost_connection" />

        <TextView
            android:id="@+id/description_lost_connection"
            style="@style/TextStyle.Body.Small.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/radius_cineVerse_s"
            android:gravity="center"
            android:text="@string/looks_like_you_re_offline_let_s_reconnect_so_you_don_t_miss_out"
            android:textColor="@color/shade_secondary_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/button_retry"
            app:layout_constraintTop_toBottomOf="@id/title_lost_connection" />

        <Button
            android:id="@+id/button_retry"
            style="@style/TextStyle.Body.Small.Medium"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/radius_cineVerse_size3xl"
            android:background="@drawable/button_background"
            android:onClick="@{() -> viewModel.getData()}"
            android:text="@string/try_again"
            android:textColor="@color/button_color_onPrimary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/description_lost_connection"/>


        <androidx.constraintlayout.widget.Group
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="title_lost_connection,animation_lost_connection,description_lost_connection,button_retry"
            app:showWhenNoInternet="@{viewModel.createdListUIState.error}" />

        <!-- empty List -->

        <ImageView
            android:id="@+id/no_data"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/circle_disabled_my_collection"
            android:padding="18dp"
            android:src="@drawable/due_tone_video_library"
            app:layout_constraintBottom_toTopOf="@+id/title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            app:tint="@color/brand_color_primary" />

        <TextView
            android:id="@+id/title"
            style="@style/TextStyle.Title.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/radius_cineVerse_xl"
            android:text="@string/no_collections_yet"
            android:textColor="@color/shade_color_primary"
            app:layout_constraintBottom_toTopOf="@id/description_empty_list"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/no_data" />

        <TextView
            android:id="@+id/description_empty_list"
            style="@style/TextStyle.Body.Small.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/radius_cineVerse_s"
            android:gravity="center"
            android:text="@string/start_building_your_personal_library_by_saving_movies_or_series_you_want_to_remember"
            android:textColor="@color/shade_color_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/button_empty"
            app:layout_constraintTop_toBottomOf="@id/title" />

        <Button
            android:id="@+id/button_empty"
            style="@style/TextStyle.Body.Small.Medium"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/radius_cineVerse_size3xl"
            android:background="@drawable/button_background"
            android:text="@string/start_collecting"
            android:textColor="@color/button_color_onPrimary"
            android:onClick="@{() -> viewModel.onStartCollectingClicked()}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/description_empty_list" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/empty_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="description_empty_list,title,no_data, button_empty"
            app:isListEmpty="@{viewModel.createdListUIState.isEmpty}" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>