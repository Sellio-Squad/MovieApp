<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Checked state (ON) - Solid color background -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_color_primary" />
            <corners android:radius="@dimen/radius_cineVerse_full" />
            <size android:width="40dp" android:height="24dp" />
        </shape>
    </item>

    <!-- Unchecked state (OFF) - Transparent with border -->
    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:radius="@dimen/radius_cineVerse_full" />
            <size android:width="40dp" android:height="24dp" />
            <stroke android:width="1dp" android:color="@color/shade_color_secondary" />
        </shape>
    </item>
</selector>
