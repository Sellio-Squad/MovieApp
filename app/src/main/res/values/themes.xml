<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application ChangeThemeUseCase. -->
    <style name="Theme.MovieApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/brand_color</item>
        <item name="colorPrimaryVariant">@color/background_color</item>

        <item name="android:statusBarColor">@color/background_color</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <item name="textInputStyle">@style/Login</item>
        <item name="actionBarTheme">@style/MyTheme</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>

    </style>

    <style name="Theme.MovieApp.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_color</item>
        <item name="colorPrimaryVariant">@color/background_color</item>

        <!-- Status bar setup -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <!-- Your existing styles -->
        <item name="textInputStyle">@style/Login</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>
    </style>


    <style name="large_button" parent="TextAppearance.AppCompat.Button">
        <item name="android:radius">@dimen/radius_cineVerse_l</item>
    </style>

    <style name="large_button.enabled" parent="TextAppearance.AppCompat.Button">
        <item name="backgroundTint"> @color/button_color_primary</item>
    </style>

    <style name="large_button.disabled" parent="TextAppearance.AppCompat.Button">
        <item name="backgroundTint">@color/button_color_disabled </item>
    </style>

    <style name="small_button" parent="TextAppearance.AppCompat.Button">
        <item name="android:radius">@dimen/radius_cineVerse_m</item>
    </style>

    <style name="small_button.enabled" parent="TextAppearance.AppCompat.Button">
        <item name="backgroundTint">@color/button_color_onTertiary</item>
    </style>

    <style name="small_button..disabled" parent="TextAppearance.AppCompat.Button">
        <item name="backgroundTint">@color/button_color_disabled</item>
    </style>



    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="AppModalStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/bottom_sheet_corners</item>
    </style>


    <style name="MyTheme" parent="@style/ThemeOverlay.MaterialComponents.ActionBar">
        <item name="android:background">@color/background_color</item>
        <item name="android:textColorPrimary">@color/shade_primary_color</item>
        <item name="contentInsetStartWithNavigation">0dp</item>
        <item name="contentInsetStart">0dp</item>
    </style>


    <style name="SemiBold">
        <item name="android:fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="android:textColor">@color/shade_primary_color</item>
    </style>

    <style name="SemiBold.Large">
        <item name="android:textSize">@dimen/text_large</item>
    </style>

    <style name="SemiBold.Medium">
        <item name="android:textSize">@dimen/text_medium</item>
    </style>

    <style name="SemiBold.Small">
        <item name="android:textSize">@dimen/text_small</item>
    </style>


    <style name="Regular">
        <item name="android:fontFamily">@font/plus_jakarta_sans_regular</item>
    </style>

    <style name="Regular.Medium">
        <item name="android:textSize">@dimen/text_medium</item>
    </style>

    <style name="Regular.Medium.Primary">
        <item name="android:textColor">@color/shade_primary_color</item>
    </style>

    <style name="Regular.Medium.Secondary">
        <item name="android:textColor">@color/shade_secondary_color</item>
    </style>


    <style name="Regular.Small">
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textColor">@color/shade_primary_color</item>
    </style>

    <style name="Regular.Small.Secondary">
        <item name="android:textColor">@color/shade_secondary_color</item>
    </style>

    <style name="Regular.Small.ternary">
        <item name="android:textColor">@color/shade_ternary_color</item>
    </style>


    <style name="CardCorners">
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="CardCorners.Small">
        <item name="cornerSize">@dimen/radius_small</item>
    </style>

    <style name="CardCorners.Medium">
        <item name="cornerSize">@dimen/radius_medium</item>
    </style>

    <style name="CardCorners.large">
        <item name="cornerSize">@dimen/radius_cineVerse_l</item>
    </style>

    <style name="CardCorners.TopOnlyRounded" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/radius_cineVerse_size5xl</item>
        <item name="cornerSizeTopRight">@dimen/radius_cineVerse_size5xl</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>


    <style name="CardCorners.Custom">
        <item name="cornerSizeBottomLeft">@dimen/radius_small</item>
        <item name="cornerSizeBottomRight">@dimen/radius_medium</item>
        <item name="cornerSizeTopLeft">@dimen/radius_medium</item>
        <item name="cornerSizeTopRight">@dimen/radius_small</item>
    </style>

    <style name="PosterShapeStyle" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">16dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="Login" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <!-- Text appearance -->
        <item name="android:textColorHint">@color/shade_color_tertiary</item>
        <item name="hintTextAppearance">@style/TextStyle.Body.Medium.Regular</item>
        <item name="hintTextColor">@color/shade_color_tertiary</item>

        <!-- Disable floating label -->
        <item name="hintEnabled">false</item>

        <!-- Box styling -->
        <item name="boxBackgroundColor">@color/background_color_card</item>
        <item name="boxStrokeColor">@color/text_input_stroke_selector</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>

        <!-- Corner radius -->
        <item name="boxCornerRadiusTopStart">@dimen/radius_cineVerse_l</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_cineVerse_l</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_cineVerse_l</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_cineVerse_l</item>

        <!-- Icons -->
        <item name="startIconTint">@color/shade_color_tertiary</item>
        <item name="endIconTint">@color/shade_color_secondary</item>
        <item name="passwordToggleTint">@color/shade_color_secondary</item>
        <item name="passwordToggleDrawable">@drawable/cineverse_password_toggle</item>


        <!-- Error styling -->
        <item name="errorEnabled">true</item>
        <item name="errorTextAppearance">@style/TextStyle.Body.Small.Regular</item>
        <item name="errorTextColor">@color/additional_color_primary_color_red</item>
        <item name="errorIconDrawable">@drawable/outline_danger_triangle</item>
        <item name="errorIconTint">@color/additional_color_primary_color_red</item>

        <!-- Helper text -->
        <item name="helperTextEnabled">false</item>
    </style>

    <!-- CineVerse Button Styles -->
    <style name="CineVerseButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="cornerRadius">@dimen/radius_cineVerse_l</item>
    </style>

    <style name="CineVerseButton.Primary">
        <item name="android:textAppearance">@style/TextStyle.Body.Medium.Medium</item>
        <item name="android:textColor">@color/button_color_onPrimary</item>
        <item name="backgroundTint">@color/button_state_primary</item>
    </style>

    <style name="CineVerseButton.Secondary">
        <item name="android:textAppearance">@style/TextStyle.Body.Medium.Regular</item>
        <item name="android:textColor">@color/button_color_onSecondary</item>
        <item name="backgroundTint">@color/button_state_secondary</item>
    </style>

    <!-- the EditText inside -->
    <style name="LoginEditText">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/shade_color_primary</item>
        <item name="android:textCursorDrawable">@drawable/text_cursor</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Theme.MovieApp.SplashScreen" parent="Theme.SplashScreen.IconBackground">
        <item name="postSplashScreenTheme">@style/Theme.MovieApp</item>
        <item name="windowSplashScreenBackground">@color/background_color</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>


    <style name="CardCorners.BottomMedium">
        <item name="cornerSizeBottomLeft">@dimen/radius_medium</item>
        <item name="cornerSizeBottomRight">@dimen/radius_medium</item>
    </style>


    <style name="Circle">
        <item name="cornerSize">50%</item>
    </style>

    <style name="Chip.Regular.Small" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipStrokeColor">@color/chip_stroke</item>
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textAlignment">center</item>
    </style>


    <style name="chipChip" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipStrokeColor">@color/brand_color</item>
        <item name="chipSurfaceColor">@color/shade_secondary_color</item>
        <item name="chipStrokeWidth">@dimen/cardview_compat_inset_shadow</item>
    </style>

    <style name="Colors_Widget.MaterialComponents.Chip.Choice" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/selector_chip_background</item>
        <item name="chipStrokeColor">@color/selector_chip_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/selector_chip_text</item>
        <item name="chipCornerRadius">@dimen/radius_cineVerse_full</item>
    </style>


    <style name="Regular.Small.Primary">
        <item name="android:textColor">@color/shade_primary_color</item>

    </style>

    <!-- Text styles for the CineVerse -->
    <style name="TextStyle.Display">
        <item name="android:fontFamily">@font/manrope_bold</item>
        <item name="android:textSize">40sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Title.ExtraLarge">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextStyle.Title.Large">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextStyle.Title.Medium">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/shade_color_primary</item>
    </style>

    <style name="TextStyle.Title.Small">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- Body Large -->
    <style name="TextStyle.Body.Large.Regular">
        <item name="android:fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="TextStyle.Body.Large.Medium">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="TextStyle.Body.Large.SemiBold">
        <item name="android:fontFamily">@font/manrope_semi_bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- Body Medium -->
    <style name="TextStyle.Body.Medium.Regular">
        <item name="android:fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="TextStyle.Body.Medium.Medium">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/button_color_onSecondary</item>
    </style>
    <style name="TextStyle.Body.Medium.SemiBold">
        <item name="android:fontFamily">@font/manrope_semi_bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- Body Small -->
    <style name="TextStyle.Body.Small.Regular">
        <item name="android:fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="TextStyle.Body.Small.Medium">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="TextStyle.Body.Small.SemiBold">
        <item name="android:fontFamily">@font/manrope_semi_bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- Label Large -->
    <style name="TextStyle.Label.Large.Regular">
        <item name="android:fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="TextStyle.Label.Large.Medium">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="TextStyle.Label.Large.SemiBold">
        <item name="android:fontFamily">@font/manrope_semi_bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- Label Medium -->
    <style name="TextStyle.Label.Medium.Regular">
        <item name="android:fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="TextStyle.Label.Medium.Medium">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="TextStyle.Label.Medium.SemiBold">
        <item name="android:fontFamily">@font/manrope_semi_bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- Label Small -->
    <style name="TextStyle.Label.Small.Regular">
        <item name="android:fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="TextStyle.Label.Small.Medium">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="TextStyle.Label.Small.SemiBold">
        <item name="android:fontFamily">@font/manrope_semi_bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextStyle.Body.Large" parent="TextStyle.Body.Large.Regular" />
    <style name="TextStyle.Body.Medium" parent="TextStyle.Body.Medium.Regular" />
    <style name="TextStyle.Body.Small" parent="TextStyle.Body.Small.Regular" />
    <style name="TextStyle.Label.Large" parent="TextStyle.Label.Large.Regular" />
    <style name="TextStyle.Label.Medium" parent="TextStyle.Label.Medium.Regular" />
    <style name="TextStyle.Label.Small" parent="TextStyle.Label.Small.Regular" />
    <style name="TextStyle.Title" parent="TextStyle.Title.Medium" />

    <style name="TextStyle" parent="TextStyle.Title.Medium" />

    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="textAllCaps">false</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="CastImage">
        <item name="cornerSizeTopLeft">12dp</item>
        <item name="cornerSizeTopRight">12dp</item>
        <item name="cornerSizeBottomLeft">12dp</item>
    </style>

    <style name="MovieAppFabStyle" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="shapeAppearanceOverlay">@style/MovieAppFabCorners</item>
    </style>

    <style name="MovieAppFabCorners">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_cineVerse_l</item>
    </style>
    <style name="ctaCard">
        <item name="android:background">@drawable/rating_card</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_marginStart">@dimen/spacing_medium</item>
        <item name="android:layout_marginEnd">@dimen/spacing_medium</item>
    </style>


    <style name="CtaText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/manrope_medium</item>
    </style>

    <style name="CtaText.Title">
        <item name="android:textColor">@color/shade_color_primary</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="CtaText.Description">
        <item name="android:textColor">@color/shade_color_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="cast_image" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/radius_cineVerse_l</item>
        <item name="cornerSizeTopRight">@dimen/radius_cineVerse_l</item>
        <item name="cornerSizeBottomLeft">@dimen/radius_cineVerse_l</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>


    <style name="FloatingBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
        <item name="android:windowIsFloating">true</item> <!-- This is crucial for it to behave like a dialog -->
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item> <!-- Important for transparency -->
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/bg_floating_bottom_sheet</item>
    </style>


    <style name="MediaPhotoCorners">
        <item name="cornerSizeTopLeft">@dimen/radius_cineVerse_l</item>
        <item name="cornerSizeTopRight">@dimen/radius_cineVerse_l</item>
        <item name="cornerSizeBottomLeft">@dimen/radius_cineVerse_l</item>
    </style>
</resources>
