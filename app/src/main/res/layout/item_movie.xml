<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.adapters.MovieInteractionListener" />

        <variable
            name="item"
            type="com.karrar.movieapp.ui.models.MediaUiState" />

        <variable
            name="type"
            type="com.karrar.movieapp.domain.enums.HomeItemsType" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="0dp"
            android:layout_height="@dimen/media_card_height"
            android:layout_marginHorizontal="@dimen/spacing_medium"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="136:182"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:background="@color/brand_color_primary"
            app:layout_constraintTop_toTopOf="parent"
            android:onClick="@{()->listener.onClickMovie(item.id)}"
            app:posterImage="@{item.imageUrl}"
            app:shapeAppearanceOverlay="@style/CardCorners.Medium"
            android:id="@+id/img_poster"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="@id/img_poster"
            app:layout_constraintEnd_toEndOf="@id/img_poster"
            android:padding="@dimen/spacing_small"
            android:background="@drawable/media_rate_background"
            android:paddingHorizontal="6dp"
            android:paddingVertical="4dp"
            android:layout_margin="@dimen/spacing_small">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{String.format(`%.1f`, item.rate)}"
                tools:text="5.7"
                android:textColor="@color/shade_color_primary"/>
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="@dimen/spacing_too_small"
                android:src="@drawable/ic_rate"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>